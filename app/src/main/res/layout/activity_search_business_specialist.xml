<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".simpleUserActivities.SearchBusinessSpecialist">


    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_baseline_arrow_back_24"
        app:layout_constraintBottom_toTopOf="@+id/guideline41"
        app:layout_constraintEnd_toStartOf="@+id/guideline42"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline41"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="65dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline42"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="84dp" />

    <TextView
        android:layout_width="310dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Επέλεξε την πόλη του επαγγελματια"
        android:textColor="@color/black"
        android:textSize="17sp"
        app:layout_constraintBottom_toTopOf="@+id/CitySpinner"
        app:layout_constraintEnd_toEndOf="@+id/CitySpinner"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/cityPhoto" />

    <ImageView
        android:id="@+id/cityPhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_city"
        android:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="@+id/CitySpinner"
        app:layout_constraintEnd_toStartOf="@+id/CitySpinner"
        app:layout_constraintTop_toTopOf="@+id/CitySpinner" />

    <com.toptoche.searchablespinnerlibrary.SearchableSpinner
        android:id="@+id/CitySpinner"
        android:layout_width="290dp"
        android:layout_height="40dp"
        android:dropDownWidth="wrap_content"
        android:entries="@array/Cities"
        app:layout_constraintBottom_toTopOf="@+id/TypeSpecializationSpinner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/businessPhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_baseline_business_24"
        android:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="@+id/TypeSpecializationSpinner"
        app:layout_constraintEnd_toStartOf="@+id/TypeSpecializationSpinner"
        app:layout_constraintTop_toTopOf="@+id/TypeSpecializationSpinner" />

    <TextView
        android:layout_width="310dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Επέλεξε την κατηγορία επαγγελματία"
        android:textColor="@color/black"
        android:textSize="17sp"
        app:layout_constraintBottom_toTopOf="@+id/TypeSpecializationSpinner"
        app:layout_constraintEnd_toEndOf="@+id/TypeSpecializationSpinner"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/businessPhoto" />

    <com.toptoche.searchablespinnerlibrary.SearchableSpinner
        android:id="@+id/TypeSpecializationSpinner"
        android:layout_width="290dp"
        android:layout_height="40dp"
        android:entries="@array/Αθλητισμός"
        app:layout_constraintBottom_toTopOf="@+id/guideline3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/CitySpinner"/>

    <Button
        android:id="@+id/searchButton"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:background="@drawable/search_button"
        android:text="Αναζήτηση"
        android:textAllCaps="false"
        android:textSize="24sp"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline3" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="248dp" />
</androidx.constraintlayout.widget.ConstraintLayout>