<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/groups_background"
    tools:context=".registration.GroupRegistration">

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_baseline_arrow_back_24"
        app:layout_constraintBottom_toTopOf="@+id/guideline41"
        app:layout_constraintEnd_toStartOf="@+id/guideline42"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline41"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="65dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline42"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="84dp" />


    <ImageButton
        android:id="@+id/addServiceButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="@+id/newServiceEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/newServiceEditText"
        app:layout_constraintTop_toTopOf="@+id/newServiceEditText"
        />

    <TextView
        android:id="@+id/addServicesTextView"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:text="@string/addServiceGroupText"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="23dp"
        app:layout_constraintBottom_toTopOf="@id/newServiceEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline41" />

    <EditText
        android:id="@+id/newServiceEditText"
        android:layout_width="250dp"
        android:layout_height="40dp"
        android:background="@drawable/group_edit_text_ring"
        android:ems="10"
        android:hint="@string/addNewServiseGroup"
        android:inputType="textPersonName"
        android:maxLength="100"
        android:padding="10dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/groupRecyclerView"
        app:layout_constraintEnd_toStartOf="@+id/addServiceButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addServicesTextView"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/groupRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="405dp"
        android:background="@drawable/recycler_view_backgroud"
        app:layout_constraintBottom_toTopOf="@+id/finishGroupButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/newServiceEditText" />

    <Button
        android:id="@+id/finishGroupButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/group_finish_button"
        android:text="@string/finishButton"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/groupRecyclerView"
        app:layout_constraintStart_toEndOf="@id/questionmarkButton"/>

    <ImageButton
        android:id="@+id/questionmarkButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_info"
        app:layout_constraintBottom_toBottomOf="@+id/finishGroupButton"
        app:layout_constraintEnd_toStartOf="@+id/finishGroupButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/finishGroupButton" />


</androidx.constraintlayout.widget.ConstraintLayout>